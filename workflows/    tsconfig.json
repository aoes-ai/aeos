{
    "compilerOptions": {
      "target": "ES2022",
      "module": "NodeNext",
      "moduleResolution": "NodeNext",
      "rootDir": ".",
      "outDir": "dist",
      "strict": true,
      "esModuleInterop": true,
      "resolveJsonModule": true,
      "skipLibCheck": true,
      "forceConsistentCasingInFileNames": true
    },
    "include": [
      "apps/**/*.ts",
      "agents/**/*.ts",
      "orchestration/**/*.ts",
      "router/**/*.ts",
      "tools/**/*.ts",
      "scripts/**/*.ts"
    ],
    "exclude": [
      "node_modules",
      "dist"
    ]
  }